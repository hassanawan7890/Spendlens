<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="56dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="20dp"
    android:foreground="?attr/selectableItemBackground">
    <TextView android:id="@+id/tvCatIcon"
        android:layout_width="36dp" android:layout_height="36dp"
        android:gravity="center" android:textSize="18sp"
        android:background="@drawable/shape_icon_bg"
        android:layout_marginEnd="14dp"/>
    <TextView android:id="@+id/tvCatName"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textSize="15sp"
        android:textColor="@color/text_primary"/>
</LinearLayout>