<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/green_800" android:orientation="vertical"
        android:paddingHorizontal="20dp" android:paddingTop="44dp" android:paddingBottom="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/white"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Smart Insights" android:textSize="20sp" android:textColor="@color/white"
                android:fontFamily="sans-serif-medium" android:layout_marginStart="12dp"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <!-- Leak detector card -->
            <androidx.cardview.widget.CardView android:id="@+id/cardLeak"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="16dp"
                app:cardElevation="0dp" app:cardBackgroundColor="@color/red_50"
                app:strokeColor="@color/red_100" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔍  Hidden Leak Detector"
                        android:textSize="14sp" android:textColor="@color/red_700"
                        android:fontFamily="sans-serif-medium" android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvLeakResult"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/red_700"
                        android:lineSpacingMultiplier="1.5"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Risk meter card -->
            <androidx.cardview.widget.CardView android:id="@+id/cardRisk"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="16dp"
                app:cardElevation="0dp" app:cardBackgroundColor="@color/amber_50"
                app:strokeColor="@color/amber_100" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡  Weekly Risk Meter"
                        android:textSize="14sp" android:textColor="@color/amber_700"
                        android:fontFamily="sans-serif-medium" android:layout_marginBottom="10dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <View android:id="@+id/riskSeg0" android:layout_width="0dp"
                            android:layout_height="8dp" android:layout_weight="1"
                            android:background="@color/green_600" android:layout_marginEnd="4dp"/>
                        <View android:id="@+id/riskSeg1" android:layout_width="0dp"
                            android:layout_height="8dp" android:layout_weight="1"
                            android:background="@color/amber_400" android:layout_marginEnd="4dp"/>
                        <View android:id="@+id/riskSeg2" android:layout_width="0dp"
                            android:layout_height="8dp" android:layout_weight="1"
                            android:background="@color/amber_600" android:layout_marginEnd="4dp"/>
                        <View android:id="@+id/riskSeg3" android:layout_width="0dp"
                            android:layout_height="8dp" android:layout_weight="1"
                            android:background="@color/red_600"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvRiskResult"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/amber_700"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Personality card -->
            <androidx.cardview.widget.CardView android:id="@+id/cardPersonality"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="16dp"
                app:cardElevation="0dp" app:cardBackgroundColor="@color/purple_50"
                app:strokeColor="@color/purple_200" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧠  Spending Personality"
                        android:textSize="14sp" android:textColor="@color/purple_800"
                        android:fontFamily="sans-serif-medium" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvPersonalityName"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="20sp" android:textColor="@color/purple_600"
                        android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tvPersonalityDesc"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/purple_600"
                        android:lineSpacingMultiplier="1.5"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Reflection card -->
            <androidx.cardview.widget.CardView android:id="@+id/cardReflection"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/gray_100" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📅  Weekly Reflection"
                        android:textSize="14sp" android:textColor="@color/gray_900"
                        android:fontFamily="sans-serif-medium" android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvReflectionContent"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/gray_700"
                        android:lineSpacingMultiplier="1.6"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>